{
  "manifest_version": 3,
  "name": "Tab Sound Mixer 500% Volume Booster",
  "description": "Per-site and per-tab mixer with up to 500% GainNode volume boost and saved presets.",
  "version": "1.1.1",
  "permissions": ["tabs", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/low-volume-16.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/low-volume-16.png",
    "48": "icons/low-volume-48.png",
    "128": "icons/low-volume-128.png"
  },
  "host_permissions": ["http://*/*", "https://*/*"]
}
